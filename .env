# Flask
FLASK_SECRET_KEY=replace_with_a_long_random_secret

# MySQL (used by mysql.connector)
MYSQL_HOST=replace_with_mysql_host
MYSQL_PORT=3306
MYSQL_USER=replace_with_mysql_user
MYSQL_PASSWORD=replace_with_mysql_password
MYSQL_DATABASE=replace_with_mysql_database

# Email (OTP)
SMTP_EMAIL=replace_with_gmail_address
SMTP_APP_PASSWORD=replace_with_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SQLAlchemy (used by Flask-SQLAlchemy models)
# Keep sqlite for now unless you migrate this part to MySQL/Postgres
SQLALCHEMY_DATABASE_URI=sqlite:///campus.db
